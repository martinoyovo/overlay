{
  "name": "overlay-desktop",
  "version": "1.0.0",
  "description": "Overlay — AI assistant with universal content capture",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd ../frontend && BROWSER=none PORT=3005 npm start",
    "dev:main": "tsc -p tsconfig.main.json && electron . --dev",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd ../frontend && npm run build",
    "package": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "ai",
    "desktop",
    "ocr",
    "text-capture",
    "electron",
    "react"
  ],
  "author": "AI Browser Assistant Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "python-shell": "^5.0.0",
    "screenshot-desktop": "^1.12.7",
    "sharp": "^0.33.0",
    "tesseract.js": "^4.1.1"
  },
  "build": {
    "appId": "com.overlay.desktop",
    "productName": "Overlay",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "frontend/build/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "frontend/build",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
